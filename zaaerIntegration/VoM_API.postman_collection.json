{
	"info": {
		"_postman_id": "vom-api-integration-2025",
		"name": "VoM API Integration",
		"description": "VoM Partner API Integration Collection\n\nEndpoints:\n1. Login - Get Bearer Token\n2. Get Accounts - Fetch accounting accounts",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "VoM Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.token) {",
									"        pm.environment.set(\"vom_token\", jsonData.token);",
									"        console.log(\"✅ Token saved to environment variable: vom_token\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"Info@aleairygroup.com\",\n  \"password\": \"Aa1xyjPlNHd\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/vom/VoMAuth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"vom",
								"VoMAuth",
								"login"
							]
						},
						"description": "Login to VoM API and get Bearer Token.\n\n**Credentials:**\n- Email: Info@aleairygroup.com\n- Password: Aa1xyjPlNHd\n\n**Response:**\n- Returns Bearer Token that will be automatically saved to `vom_token` environment variable"
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/vom/VoMAuth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"vom",
								"VoMAuth",
								"refresh"
							]
						},
						"description": "Refresh the Bearer Token if it has expired."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for VoM API"
		},
		{
			"name": "Accounts",
			"item": [
				{
					"name": "Get All Accounts",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{vom_token}}",
								"type": "text",
								"description": "Bearer Token from Login endpoint"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/vom/VoMAccount?language={{language}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"vom",
								"VoMAccount"
							],
							"query": [
								{
									"key": "language",
									"value": "{{language}}",
									"description": "Language: 'en' or 'ar'",
									"disabled": false
								}
							]
						},
						"description": "Get all accounting accounts from VoM API.\n\n**Required:**\n- Bearer Token in Authorization header\n\n**Query Parameters:**\n- language: 'en' (English) or 'ar' (Arabic) - Default: 'en'"
					},
					"response": []
				}
			],
			"description": "Account management endpoints"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-set base_url if not set",
					"if (!pm.environment.get(\"base_url\")) {",
					"    pm.environment.set(\"base_url\", \"https://aleairy.tryasp.net\");",
					"    console.log(\"✅ base_url set to: https://aleairy.tryasp.net\");",
					"}",
					"",
					"// Auto-set language if not set",
					"if (!pm.environment.get(\"language\")) {",
					"    pm.environment.set(\"language\", \"en\");",
					"    console.log(\"✅ language set to: en\");",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "https://aleairy.tryasp.net",
			"type": "string"
		},
		{
			"key": "vom_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "language",
			"value": "en",
			"type": "string"
		}
	]
}
